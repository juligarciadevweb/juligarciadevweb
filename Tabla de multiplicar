<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Multiplicacion</title>
</head>
<body>
    <script>
    var numero;
    numero=prompt('Ingrese un numero(1-70)','')
    numero=parseInt(numero)
    document.write("<p><h2>Su tabla es:</h2></p>")    
    document.write("<table border='3px' black>")
 
    var x=0;
 
    for (x = 1; x <= 10; x++)
    {
	    tabla=numero*x;
	    document.write("<tr><td>")
	    document.write(numero+"x"+x+"="+ tabla + "<br>")
	    document.write("</td></tr>")
    }
 
    document.write("</table>")
    </script>
</body>
</html>
